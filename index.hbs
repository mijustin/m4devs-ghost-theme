{{!< default}}
{{!-- Default index template - redirects to home for this theme --}}
{{!-- This is a fallback; the home.hbs handles the actual homepage via routes.yaml --}}

<div class="db-index-page">
    <header class="db-page-header">
        <div class="db-section-inner">
            <h1 class="db-page-title">{{@site.title}}</h1>
            {{#if @site.description}}
            <p class="db-page-subtitle">{{@site.description}}</p>
            {{/if}}
        </div>
    </header>

    <section class="db-posts-section">
        <div class="db-section-inner">
            {{#if posts}}
            <div class="db-post-feed">
                {{#foreach posts}}
                {{> "post-card"}}
                {{/foreach}}
            </div>
            {{pagination}}
            {{else}}
            <div class="db-empty-state">
                <p>No posts yet. Check back soon!</p>
            </div>
            {{/if}}
        </div>
    </section>
</div>

