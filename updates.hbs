{{!< default}}
{{!-- Updates/Blog collection template --}}

<div class="db-updates-page">
    <header class="db-updates-header">
        <div class="db-section-inner">
            <h1 class="db-page-title">Updates</h1>
            <p class="db-page-subtitle">News, tips, and behind-the-scenes on the book rewrite</p>
        </div>
    </header>

    <section class="db-updates-content">
        <div class="db-section-inner">
            {{#if posts}}
            <div class="db-post-feed">
                {{#foreach posts}}
                {{> "post-card"}}
                {{/foreach}}
            </div>

            {{pagination}}
            {{else}}
            <div class="db-empty-state">
                <p>No updates yet. Check back soon!</p>
            </div>
            {{/if}}
        </div>
    </section>

    {{!-- Newsletter CTA --}}
    {{> "cta-footer" headline="Get updates in your inbox" subheadline="Join the email list to get free chapters and new marketing tips." button_text="Subscribe for free"}}
</div>

