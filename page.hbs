{{!< default}}
{{!-- Static page template --}}

{{#post}}
<article class="db-page {{post_class}}">
    <header class="db-page-header">
        <div class="db-section-inner">
            {{#match @page.show_title_and_feature_image}}
            <h1 class="db-page-title">{{title}}</h1>
            {{/match}}
        </div>
    </header>

    {{#match @page.show_title_and_feature_image}}
    {{#if feature_image}}
    <figure class="db-page-image">
        <img 
            srcset="{{img_url feature_image size="s"}} 300w,
                    {{img_url feature_image size="m"}} 600w,
                    {{img_url feature_image size="l"}} 1000w,
                    {{img_url feature_image size="xl"}} 2000w"
            sizes="(min-width: 1200px) 1000px, 90vw"
            src="{{img_url feature_image size="l"}}"
            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
        >
        {{#if feature_image_caption}}
        <figcaption>{{feature_image_caption}}</figcaption>
        {{/if}}
    </figure>
    {{/if}}
    {{/match}}

    <section class="db-page-content gh-content">
        <div class="db-section-inner">
            {{content}}
        </div>
    </section>
</article>
{{/post}}

