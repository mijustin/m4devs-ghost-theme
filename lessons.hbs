{{!< default}}
{{!-- Lessons archive: table of contents for #new-lessons posts --}}

<div class="db-lessons-page">
    <header class="db-book-header">
        <div class="db-section-inner">
            <h1 class="db-page-title">Lessons</h1>
            <p class="db-page-subtitle">Marketing advice for developers in the AI era</p>
        </div>
    </header>

    <section class="db-book-content">
        <div class="db-section-inner">
            {{#get "posts" filter="tag:hash-new-lessons" order="published_at asc" limit="50"}}
            {{#if posts}}
            <div class="db-chapter-list">
                {{#foreach posts}}
                {{> "chapter-item"}}
                {{/foreach}}
            </div>
            {{else}}
            <div class="db-empty-state">
                <p>No lessons have been published yet. Check back soon!</p>
            </div>
            {{/if}}
            {{/get}}
        </div>
    </section>
</div>
