{{!< default}}
{{!-- Homepage template for Marketing for Developers --}}

{{!-- Hero Section --}}
<section class="db-hero">
    <div class="db-hero-inner">
        <div class="db-hero-content">
            <h1 class="db-hero-title">{{@custom.hero_heading}}</h1>
            <p class="db-hero-subtitle">{{@custom.hero_subheading}}</p>
        </div>
        
        {{!-- Two column: Image | Text --}}
        <div class="db-hero-main">
            <div class="db-hero-image">
                {{#if @custom.author_image}}
                <img src="{{@custom.author_image}}" alt="Author photo">
                {{else}}
                <img src="{{asset "images/author-placeholder.png"}}" alt="Author photo">
                {{/if}}
                <div class="db-hero-image-frame"></div>
            </div>
            
            <div class="db-hero-text">
                <p>{{@custom.hero_text}}</p>
            </div>
        </div>

        {{!-- CTA below, full width --}}
        <div class="db-hero-cta">
            {{#if @site.members_enabled}}
                {{#if @member}}
                <p class="db-hero-cta-text">You're on the list! Want to share this site with a friend?</p>
                <button class="db-btn db-btn-primary db-btn-lg" onclick="navigator.share ? navigator.share({title: '{{@site.title}}', url: '{{@site.url}}'}) : navigator.clipboard.writeText('{{@site.url}}').then(() => this.textContent = 'Link copied!')">
                    <span>Share</span>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="18" cy="5" r="3"></circle>
                        <circle cx="6" cy="12" r="3"></circle>
                        <circle cx="18" cy="19" r="3"></circle>
                        <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
                        <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
                    </svg>
                </button>
                {{else}}
                <p class="db-hero-cta-text">{{@custom.email_cta_text}}</p>
                <a class="db-btn db-btn-primary db-btn-lg" href="#/portal/signup" data-portal="signup">
                    <span>Join the list</span>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                </a>
                {{/if}}
            {{/if}}
        </div>
    </div>
    
    {{!-- Decorative elements --}}
    <div class="db-hero-decoration">
        <div class="db-pixel-corner db-pixel-corner-tl"></div>
        <div class="db-pixel-corner db-pixel-corner-br"></div>
    </div>
</section>

{{!-- Who is this for Section --}}
<section class="db-audience-section">
    <div class="db-section-inner">
        <header class="db-section-header">
            <h2 class="db-section-title">{{@custom.who_is_this_for_heading}}</h2>
            <p class="db-section-subtitle">{{@custom.who_is_this_for_text}}</p>
        </header>
        <div class="db-audience-content">
            <ul class="db-audience-list">
                <li>Developers building side projects who want to find their first customers</li>
                <li>Technical founders who need to learn marketing fundamentals</li>
                <li>Programmers creating products with AI who want to stand out</li>
                <li>Indie hackers looking for practical, no-BS marketing advice</li>
            </ul>
        </div>
    </div>
</section>

{{!-- Pricing Section --}}
<section class="db-pricing-section">
    <div class="db-section-inner">
        <header class="db-section-header">
            <h2 class="db-section-title">Join the Community</h2>
            <p class="db-section-subtitle">Get the marketing advice and support you need to launch your next product</p>
        </header>

        <div class="db-pricing-single">
            {{!-- Membership Option --}}
            <div class="db-pricing-card db-pricing-featured">
                <div class="db-pricing-badge">Best Value</div>
                <h3 class="db-pricing-name">Community Membership</h3>
                <div class="db-pricing-price">
                    <span class="db-price-amount">{{@custom.membership_price}}</span>
                </div>
                <ul class="db-pricing-features">
                    <li>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                            <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                        Early access to all new marketing lessons
                    </li>
                    <li>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                            <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                        Full access to a growing library of video training
                    </li>
                    <li>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                            <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                        A private Discord community of people building + marketing
                    </li>
                    <li>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                            <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                        Access the premium podcast feed
                    </li>
                    <li>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                            <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                        Free tickets to all live workshops ($50+ value)
                    </li>
                    <li>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                            <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                        Priority support + Q&A from Justin in Discord
                    </li>
                </ul>
                {{#if @site.members_enabled}}
                <a class="db-btn db-btn-primary db-btn-lg db-btn-block" href="/#/portal/signup/" data-portal="signup">
                    Join Membership
                </a>
                {{/if}}
            </div>
        </div>
    </div>
</section>

{{!-- Author Bio Section --}}
<section class="db-author-section">
    <div class="db-section-inner">
        <div class="db-author-content">
            {{#if @custom.author_image}}
            <div class="db-author-image">
                <img src="{{@custom.author_image}}" alt="Justin Jackson">
            </div>
            {{/if}}
            <div class="db-author-text">
                <h2 class="db-author-greeting">Hi, I'm Justin Jackson</h2>
                <p>{{@custom.author_bio}}</p>
                <div class="db-author-links">
                    <a href="https://transistor.fm/?via=justin" target="_blank" rel="noopener" class="db-author-link">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
                            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
