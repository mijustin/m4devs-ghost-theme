{{!< default}}
{{!-- Homepage: displays first #new-lessons post with lesson navigation --}}

{{#get "posts" filter="tag:hash-new-lessons" order="published_at asc" limit="1" include="authors,tags" as |lesson|}}
{{#get "posts" filter="tag:hash-new-lessons" order="published_at asc" limit="1" page="2" as |next_lesson|}}

<article class="db-lesson-home">
    <div class="db-lesson-home-inner">

        {{!-- Top breadcrumbs --}}
        <div class="db-lesson-breadcrumbs">
            <span class="db-lesson-crumb is-disabled">← Previous lesson</span>
            {{#foreach next_lesson}}
            <a href="{{url}}" class="db-lesson-crumb">Next: {{title}} →</a>
            {{else}}
            <span class="db-lesson-crumb is-disabled">Next lesson →</span>
            {{/foreach}}
        </div>

        {{#foreach lesson}}
        <header class="db-lesson-home-header">
            <h1 class="db-lesson-home-title">{{title}}</h1>
        </header>

        <section class="db-lesson-home-content gh-content">
            {{content}}
        </section>
        {{/foreach}}

        {{!-- Bottom lesson nav --}}
        <nav class="db-chapter-nav">
            <div class="db-chapter-nav-prev">
                <span class="db-chapter-nav-link is-disabled">
                    <span class="db-chapter-nav-label">← Previous lesson</span>
                    <span class="db-chapter-nav-title">You're at the beginning</span>
                </span>
            </div>
            <div class="db-chapter-nav-next">
                {{#foreach next_lesson}}
                <a href="{{url}}" class="db-chapter-nav-link">
                    <span class="db-chapter-nav-label">Next lesson →</span>
                    <span class="db-chapter-nav-title">{{title}}</span>
                </a>
                {{else}}
                <span class="db-chapter-nav-link is-disabled">
                    <span class="db-chapter-nav-label">Next lesson →</span>
                    <span class="db-chapter-nav-title">You've reached the end</span>
                </span>
                {{/foreach}}
            </div>
        </nav>

    </div>
</article>

{{/get}}
{{/get}}
