{{!< default}}
{{!-- Error page template --}}

<div class="db-error-page">
    <div class="db-error-content">
        <div class="db-error-code">
            <span class="db-error-glitch" data-text="{{statusCode}}">{{statusCode}}</span>
        </div>
        
        <h1 class="db-error-title">
            {{#match statusCode 404}}
                Page Not Found
            {{else}}
                Something Went Wrong
            {{/match}}
        </h1>
        
        <p class="db-error-message">
            {{#match statusCode 404}}
                The page you're looking for doesn't exist. It might have been moved, deleted, or maybe it never existed in the first place.
            {{else}}
                {{message}}
            {{/match}}
        </p>
        
        <div class="db-error-actions">
            <a href="{{@site.url}}" class="db-btn db-btn-primary">
                Go to Homepage
            </a>
            <a href="/book/" class="db-btn db-btn-outline">
                Read the Book
            </a>
        </div>
        
        {{!-- Retro decoration --}}
        <div class="db-error-decoration">
            <pre class="db-ascii-art">
    ╔══════════════════════════════════╗
    ║  ERROR: FILE_NOT_FOUND           ║
    ║  ────────────────────────────    ║
    ║  The requested resource could    ║
    ║  not be located on this server.  ║
    ║                                  ║
    ║  [OK]                            ║
    ╚══════════════════════════════════╝
            </pre>
        </div>
    </div>
</div>

<style>
.db-error-page {
    min-height: calc(100vh - var(--header-height) - 200px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-10) var(--space-6);
    text-align: center;
}

.db-error-content {
    max-width: 600px;
}

.db-error-code {
    font-family: var(--font-retro);
    font-size: clamp(6rem, 20vw, 12rem);
    font-weight: 700;
    line-height: 1;
    margin-bottom: var(--space-6);
    color: var(--color-text);
}

.db-error-glitch {
    position: relative;
    display: inline-block;
}

.db-error-glitch::before,
.db-error-glitch::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
}

.db-error-glitch::before {
    color: var(--color-accent-cyan);
    animation: glitch-1 2s infinite linear alternate-reverse;
    clip-path: polygon(0 0, 100% 0, 100% 45%, 0 45%);
}

.db-error-glitch::after {
    color: var(--color-accent-pink);
    animation: glitch-2 3s infinite linear alternate-reverse;
    clip-path: polygon(0 55%, 100% 55%, 100% 100%, 0 100%);
}

@keyframes glitch-1 {
    0%, 100% { transform: translate(0); }
    20% { transform: translate(-2px, 2px); }
    40% { transform: translate(-2px, -2px); }
    60% { transform: translate(2px, 2px); }
    80% { transform: translate(2px, -2px); }
}

@keyframes glitch-2 {
    0%, 100% { transform: translate(0); }
    20% { transform: translate(2px, -2px); }
    40% { transform: translate(2px, 2px); }
    60% { transform: translate(-2px, -2px); }
    80% { transform: translate(-2px, 2px); }
}

.db-error-title {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    text-transform: uppercase;
    margin-bottom: var(--space-4);
}

.db-error-message {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-8);
}

.db-error-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-4);
    margin-bottom: var(--space-10);
}

.db-error-decoration {
    margin-top: var(--space-10);
}

.db-ascii-art {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-align: left;
    display: inline-block;
    background: none;
    border: none;
    padding: 0;
}

@media (max-width: 480px) {
    .db-ascii-art {
        display: none;
    }
}
</style>

