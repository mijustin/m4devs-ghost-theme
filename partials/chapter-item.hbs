{{!-- Single chapter item for the chapter list --}}
<a href="{{url}}" class="db-chapter-item {{#has tag="#new-book"}}db-chapter-new{{/has}}">
    <div class="db-chapter-number">
        <span>{{@number}}</span>
    </div>
    
    <div class="db-chapter-content">
        <h3 class="db-chapter-title">{{title}}</h3>
        {{#if custom_excerpt}}
        <p class="db-chapter-excerpt">{{custom_excerpt}}</p>
        {{/if}}
    </div>
    
    <div class="db-chapter-meta">
        {{!-- Lock icon for new book chapters (paid content) --}}
        {{#has tag="#new-book"}}
        <span class="db-access-badge db-access-paid">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
            Members
        </span>
        {{/has}}
    </div>
    
    <div class="db-chapter-arrow">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
    </div>
</a>
