<footer class="db-footer">
    <div class="db-footer-inner">
        <div class="db-footer-brand">
            <a class="db-footer-logo" href="{{@site.url}}">
                <span>{{@site.title}}</span>
            </a>
            {{#if @site.description}}
                <p class="db-footer-description">{{@site.description}}</p>
            {{/if}}
        </div>

        <nav class="db-footer-nav">
            <ul class="db-footer-nav-list">
                <li class="db-footer-nav-item">
                    <a href="/lessons/" class="db-footer-nav-link">Lessons</a>
                </li>
                <li class="db-footer-nav-item">
                    <a href="/book/" class="db-footer-nav-link">The Book</a>
                </li>
                <li class="db-footer-nav-item">
